{
  "name": "codex-messenger",
  "version": "0.0.2-4",
  "description": "MSN Messenger-inspired Electron desktop client for running Codex locally.",
  "author": "Anis AYARI",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5174",
    "electron:dev": "node scripts/dev-electron.mjs",
    "electron:start": "npm run build && electron .",
    "electron:smoke": "npm run build && electron . --smoke-test",
    "check:codex": "node scripts/check-codex.mjs",
    "setup:codex": "node scripts/bootstrap-codex-env.mjs --ensure",
    "setup:codex:check": "node scripts/bootstrap-codex-env.mjs --check",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4174",
    "package:win": "npm run build && electron-builder --win nsis portable --x64 -c.directories.output=release/windows",
    "package:mac": "npm run package:mac:unsigned",
    "package:mac:unsigned": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip -c.directories.output=release/macos",
    "package:mac:dir": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dir -c.directories.output=release/macos",
    "package:mac:all": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip --x64 --arm64 -c.directories.output=release/macos",
    "package:mac:release": "node scripts/package-mac-release.mjs",
    "dist:win": "npm run package:win",
    "dist:mac": "npm run package:mac",
    "dist:mac:release": "npm run package:mac:release"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "playwright": "^1.59.1",
    "vite": "^7.1.12"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/anisayari/codex-messenger.git"
  },
  "bugs": {
    "url": "https://github.com/anisayari/codex-messenger/issues"
  },
  "homepage": "https://github.com/anisayari/codex-messenger#readme",
  "build": {
    "appId": "com.codex.messenger",
    "productName": "Codex Messenger",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "shared/**/*",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "icon": "public/icons/codex-messenger.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "public/icons/codex-messenger.icns",
      "category": "public.app-category.developer-tools",
      "artifactName": "Codex-Messenger-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "dmg"
        },
        {
          "target": "zip"
        }
      ],
      "extendInfo": {
        "NSCameraUsageDescription": "Codex Messenger utilise la camera uniquement pour capturer une image a envoyer dans une conversation.",
        "NSMicrophoneUsageDescription": "Codex Messenger utilise le micro uniquement pour enregistrer un clip vocal a envoyer dans une conversation."
      }
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "Codex Messenger"
    }
  }
}

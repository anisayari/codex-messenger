{
  "name": "codex-messenger",
  "version": "0.1.7",
  "description": "Client desktop Electron inspire de MSN Messenger pour piloter Codex en local.",
  "author": "Anis AYARI",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5174",
    "electron:dev": "node scripts/dev-electron.mjs",
    "electron:start": "npm run build && electron .",
    "electron:smoke": "npm run build && electron . --smoke-test",
    "check:codex": "node scripts/check-codex.mjs",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4174",
    "package:win": "npm run build && electron-builder --win nsis portable",
    "dist:win": "npm run package:win"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "playwright": "^1.59.1",
    "vite": "^7.1.12"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/anisayari/codex-messenger.git"
  },
  "bugs": {
    "url": "https://github.com/anisayari/codex-messenger/issues"
  },
  "homepage": "https://github.com/anisayari/codex-messenger#readme",
  "build": {
    "appId": "com.codex.messenger",
    "productName": "Codex Messenger",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "icon": "public/icons/codex-messenger.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Codex Messenger"
    }
  }
}
